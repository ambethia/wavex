{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "out",
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "types": [
      "node",
      "vscode"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": false
  },
  "include": [
    "src/**/*.ts"
  ]
}
