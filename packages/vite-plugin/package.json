{
  "name": "@wavex/vite-plugin",
  "version": "0.0.0",
  "type": "module",
  "description": "Vite plugin for WAVEx .wx files.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@wavex/compiler": "workspace:*",
    "@wavex/core": "workspace:*",
    "@wavex/runtime": "workspace:*"
  },
  "peerDependencies": {
    "vite": ">=5.0.0 || ^0.1.24"
  },
  "files": [
    "dist",
    "client.d.ts"
  ],
  "license": "MIT"
}
