import type { Doc } from "../../convex/_generated/dataModel"

type Attrs = { talk: Doc<"talks"> }

~~~

@card
  div [stack gap-2xs]
    div [cluster gap-s align-items-center]
      span [caption-m] {{ talk.startsAt }}
      @tag size:s {{ talk.track }}
    a href:{{ "/talks/" + talk.slug }} class:talk-link
      strong {{ talk.title }}
    p [caption-m] {{ talk.speaker }}
