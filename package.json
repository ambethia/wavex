{
  "name": "wavex-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WAVEx TypeScript-first framework workspace.",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test && pnpm docs:check",
    "typecheck": "pnpm -r typecheck",
    "test": "vp test run",
    "docs:skill": "node scripts/build-docs-skill.mjs",
    "docs:check": "node scripts/build-docs-skill.mjs --check"
  },
  "keywords": [
    "wavex",
    "wx",
    "vite",
    "lit",
    "convex"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "devDependencies": {
    "@types/node": "latest",
    "lit": "latest",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "latest",
    "vite": "latest",
    "vite-plus": "latest",
    "vitest": "latest"
  }
}
