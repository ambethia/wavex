{
  "name": "wavex-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "WAVEx TypeScript-first framework workspace.",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test && pnpm docs:check",
    "typecheck": "pnpm -r typecheck",
    "test": "vp test run",
    "docs:skill": "node scripts/build-docs-skill.mjs",
    "docs:check": "node scripts/build-docs-skill.mjs --check"
  },
  "keywords": [
    "wavex",
    "wx",
    "vite",
    "lit",
    "convex"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "overrides": {
      "@types/node": "24.9.0",
      "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
      "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "vite": "0.1.24",
        "vitest": "0.1.24"
      }
    }
  },
  "devDependencies": {
    "@types/node": "24.9.0",
    "lit": "3.3.3",
    "typedoc": "0.28.19",
    "typedoc-plugin-markdown": "4.12.0",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plus": "0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  }
}
